# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── Supabase ──
VITE_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL_HERE
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# ── Toast POS (OAuth 2.0) ──
# Obtain from: Toast Developer Portal → your app credentials
VITE_TOAST_CLIENT_ID=YOUR_TOAST_CLIENT_ID_HERE
VITE_TOAST_CLIENT_SECRET=YOUR_TOAST_CLIENT_SECRET_HERE
VITE_TOAST_RESTAURANT_GUID=YOUR_TOAST_RESTAURANT_GUID_HERE

# ── SevenRooms ──
# Obtain from: SevenRooms Dashboard → Settings → API Access
VITE_SEVENROOMS_API_KEY=YOUR_SEVENROOMS_API_KEY_HERE
VITE_SEVENROOMS_VENUE_ID=YOUR_SEVENROOMS_VENUE_ID_HERE

# ── Tripleseat ──
# Obtain from: Tripleseat → Settings → API Keys
VITE_TRIPLESEAT_API_KEY=YOUR_TRIPLESEAT_API_KEY_HERE
VITE_TRIPLESEAT_SECRET=YOUR_TRIPLESEAT_SECRET_HERE

# ── Push Operations ──
# Obtain from: Push Operations account manager (partner API access required)
# Base URL defaults to https://api.pushoperations.com — override if your account uses a subdomain
VITE_PUSH_API_KEY=YOUR_PUSH_API_KEY_HERE
VITE_PUSH_BASE_URL=https://api.pushoperations.com
